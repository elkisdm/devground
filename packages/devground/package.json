{
  "name": "@devground/devground",
  "version": "1.1.0",
  "description": "All devground standards in one package. Install once, get everything.",
  "keywords": [
    "devground",
    "standards",
    "eslint",
    "prettier",
    "tsconfig",
    "commitlint",
    "husky",
    "agents-md"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "@devground/prettier-config": "workspace:*",
    "@devground/eslint-config": "workspace:*",
    "@devground/tsconfig": "workspace:*",
    "@devground/commitlint-config": "workspace:*",
    "@devground/lint-staged-config": "workspace:*",
    "@devground/husky-config": "workspace:*",
    "@devground/agents-md": "workspace:*",
    "devground-init": "workspace:*"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "prettier": ">=3.0.0",
    "typescript": ">=5.0.0",
    "husky": ">=9.0.0",
    "lint-staged": ">=16.0.0",
    "@commitlint/cli": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "eslint-config-next": {
      "optional": true
    },
    "eslint-plugin-astro": {
      "optional": true
    },
    "astro": {
      "optional": true
    },
    "@commitlint/cli": {
      "optional": true
    }
  },
  "bin": {
    "devground-setup": "./setup.js"
  },
  "files": [
    "setup.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/elkisdm/devground.git",
    "directory": "packages/devground"
  },
  "homepage": "https://github.com/elkisdm/devground#readme",
  "bugs": {
    "url": "https://github.com/elkisdm/devground/issues"
  }
}
