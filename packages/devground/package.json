{
  "name": "@devground/devground",
  "version": "1.0.0",
  "description": "All devground standards in one package. Install once, get everything.",
  "keywords": ["devground", "standards", "eslint", "prettier", "tsconfig", "commitlint", "husky", "agents-md"],
  "license": "MIT",
  "dependencies": {
    "@devground/prettier-config": "workspace:*",
    "@devground/eslint-config": "workspace:*",
    "@devground/tsconfig": "workspace:*",
    "@devground/commitlint-config": "workspace:*",
    "@devground/lint-staged-config": "workspace:*",
    "@devground/husky-config": "workspace:*",
    "@devground/agents-md": "workspace:*"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "prettier": ">=3.0.0",
    "typescript": ">=5.0.0",
    "husky": ">=9.0.0",
    "lint-staged": ">=16.0.0",
    "@commitlint/cli": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "eslint-config-next": { "optional": true },
    "@commitlint/cli": { "optional": true }
  },
  "bin": {
    "devground-setup": "./setup.js"
  },
  "files": ["setup.js"],
  "repository": {
    "type": "git",
    "url": "https://github.com/elkisdm/devground.git",
    "directory": "packages/devground"
  }
