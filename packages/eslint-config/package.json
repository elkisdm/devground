{
  "name": "@devground/eslint-config",
  "version": "1.2.0",
  "description": "Shared ESLint flat config presets (base + Next.js)",
  "type": "module",
  "exports": {
    ".": "./index.mjs",
    "./next": "./next.mjs",
    "./ui": "./ui.mjs",
    "./astro": "./astro.mjs"
  },
  "files": [
    "*.mjs"
  ],
  "keywords": [
    "eslint",
    "config",
    "flat-config",
