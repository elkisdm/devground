{
  "name": "@devground/dev-metrics",
  "version": "1.0.0",
  "description": "Continuous, labelled time-series of how a developer evolves while coding with AI agents: code volume, quality, velocity and efficiency, computed from git history and Claude Code transcripts",
  "bin": {
    "dev-metrics": "./bin/dev-metrics.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./transcript": {
      "types": "./src/lib/transcript.ts",
      "default": "./src/lib/transcript.ts"
    },
    "./memory": {
      "types": "./src/lib/memory.ts",
      "default": "./src/lib/memory.ts"
    }
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "metrics",
    "git",
    "churn",
    "conventional-commits",
    "claude-code",
    "tokens",
    "developer-productivity",
    "time-series",
    "devground"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./transcript": {
        "types": "./dist/lib/transcript.d.ts",
        "default": "./dist/lib/transcript.js"
      },
      "./memory": {
        "types": "./dist/lib/memory.d.ts",
        "default": "./dist/lib/memory.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/elkisdm/devground.git",
    "directory": "packages/dev-metrics"
  },
  "homepage": "https://github.com/elkisdm/devground#readme",
  "bugs": {
    "url": "https://github.com/elkisdm/devground/issues"
  },
  "dependencies": {
    "@devground/logger": "workspace:*",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@devground/vitest-config": "workspace:*",
    "@types/node": "^26",
    "typescript": "^5.0.0",
    "vitest": "^2.1.0"
  }
}
