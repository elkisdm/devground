{
  "name": "devground-init",
  "version": "1.0.2",
  "description": "Interactive CLI to scaffold devground development standards (ESLint, Prettier, TypeScript, commitlint, husky, AGENTS.md, ADRs) in any Node/TypeScript/Next.js project",
  "bin": {
    "devground-init": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "cli",
    "scaffold",
    "boilerplate",
    "eslint",
    "prettier",
    "typescript",
    "husky",
    "commitlint",
    "agents-md",
    "devground"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/elkisdm/devground.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/elkisdm/devground#readme",
  "bugs": {
    "url": "https://github.com/elkisdm/devground/issues"
  },
  "dependencies": {
    "@devground/logger": "workspace:*",
    "commander": "^15.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@devground/vitest-config": "workspace:*",
    "@types/node": "^25",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.0.0",
    "vitest": "^2.1.0"
  }
}
