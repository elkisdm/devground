{
  "name": "@devground/dreaming",
  "version": "0.1.0",
  "description": "dreaming: out-of-band memory consolidation for Claude Code — reviews recent session transcripts against a project's memory store and proposes a reviewed diff (dedupe, de-stale, fill gaps, fix the index). Nothing is written without approval; nothing is hard-deleted.",
  "bin": {
    "devground-dreaming": "./dist/index.js"
  },
  "files": [
    "dist/",
    "skill/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "memory",
    "memory-consolidation",
    "dreaming",
    "context-engineering",
    "claude-code",
    "skill",
    "agents",
    "devground"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/elkisdm/devground.git",
    "directory": "packages/dreaming"
  },
  "homepage": "https://github.com/elkisdm/devground/tree/main/packages/dreaming#readme",
  "bugs": {
    "url": "https://github.com/elkisdm/devground/issues"
  },
  "dependencies": {
    "@devground/dev-metrics": "workspace:*",
    "@devground/logger": "workspace:*",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@devground/vitest-config": "workspace:*",
    "@types/node": "^25",
    "typescript": "^5.0.0",
    "vitest": "^2.1.0"
  }
}
