{
  "name": "@devground/logger",
  "version": "0.1.0",
  "description": "Tiny dependency-free console logger with ANSI-colored levels (header, info, success, warn, error) shared across devground packages",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "keywords": [
    "logger",
    "console",
    "ansi",
    "cli",
    "devground"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/elkisdm/devground.git",
    "directory": "packages/logger"
  },
  "homepage": "https://github.com/elkisdm/devground/tree/main/packages/logger#readme",
  "bugs": {
    "url": "https://github.com/elkisdm/devground/issues"
  }
}
